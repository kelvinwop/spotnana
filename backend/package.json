{
  "name": "spotnana-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "argon2": "^0.31.2",
    "crypto": "^1.0.1",
    "elysia": "^1.4.19",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.19.27",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitest/coverage-v8": "^4.0.0",
    "bun-types": "latest",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.0.0"
  }
}
